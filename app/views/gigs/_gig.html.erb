<div id="<%= dom_id gig %>">
  <p class="text-xl">
    <%= gig.name %>
  </p>
  <p>
    <%= gig.venue %>
  </p>
  <p>
    <%= gig.doors_time_only %>
  </p>

  <p>
  <% if link_acts %>
    <%= gig.acts.map { |act| act.weblink.blank? ? act.name : link_to(act.name, act.weblink, class: 'underline') }.join(", ").html_safe %>
  <% else %>
    <%= @link_acts %>
    <%= gig.acts.map { |act| act.name }.join(", ").html_safe %>
  <% end %>
  </p>

  <p>
    <%= gig.socials.split.map { |social| 
      link_to(
        social,
        "https://instagram.com/#{social.delete('@')}", 
        target: '_blank', 
        class: 'underline')
    }.join(" ").html_safe %>
  </p>
</div>
